
config voip 'global'
	option enabled '1'
	option auto_restart '1'

config trunk 'ims'
	option enabled '0'
	option port '5060'
	option context 'external'
	option nat '1'

config record
	option enabled '1'
	option dir '/tmp/voip_records'
	option auto_clean '7'

config extension '6001'
	option number '6001'
	option enabled '1'
	option secret 'secret'
	option callerid 'User 6001'
	option record '0'

config extension '6002'
	option number '6002'
	option enabled '1'
	option secret 'secret'
	option callerid 'User 6002'
	option record '0'

config ivr_option
	option digit '1'
	option action 'extension'
	option target '801'

config ivr_option
	option digit '2'
	option action 'extension'
	option target '8012'

config ivr_option
	option digit '0'
	option action 'hangup'

config pstn_handler 'pstn_handler'
	option mode 'normal'
	option playback_enabled '0'
	option playback_dir '/usr/share/asterisk/sounds'
	option playback_file 'ring'
	option playback_loop '1'
	option welcome 'ivr-welcome'
	option timeout '10'
	option invalid 'ivr-invalid'

config iax2
    option bindport '4569'
    option bindaddr '0.0.0.0'

config iax2_trunk
    option name 'server-a'
    option enabled '1'
    option host '192.168.1.10'
    option port '4569'
    option secret 'shared_secret'
    option dial_prefix '81'
    option context 'from_iax'
    option qualify '1'

config iax2_trunk
    option name 'server-b'
    option enabled '1'
    option host '192.168.1.20'
    option port '4569'
    option secret 'shared_secret'
    option dial_prefix '82'
    option context 'from_iax'
    option qualify '1'

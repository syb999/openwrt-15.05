# Multi-trunk
msgid "Configure PSTN trunks with load balancing and failover"
msgstr "配置 PSTN 中继，支持负载均衡和故障转移"

msgid "PSTN Trunks"
msgstr "PSTN 中继"

msgid "Trunk Name"
msgstr "中继名称"

msgid "Force Prefix"
msgstr "强制前缀"

msgid "Dial this prefix to force use this trunk (e.g., 9 for 9138xxxxxxx). Leave empty for automatic routing."
msgstr "拨打此前缀强制使用此中继（例如 9 表示拨打 9138xxxxxxx）。留空则自动路由。"

msgid "Weight"
msgstr "权重"

msgid "Higher weight = more calls routed to this trunk. Use for primary/backup setup."
msgstr "权重越高，分配到该中继的通话越多。可用于主备配置。"

msgid "Extension that receives incoming calls from PSTN"
msgstr "PSTN 来电时接听的分机号码"

# Global settings descriptions
msgid "Master switch for VoIP service. Disable to turn off the entire VoIP system."
msgstr "VoIP服务总开关。禁用将关闭整个VoIP系统。"

msgid "Automatically restart Asterisk when configuration changes. Disable to apply changes manually."
msgstr "配置变更时自动重启Asterisk。禁用时需要手动重启生效。"

msgid "Extension number that receives incoming calls from PSTN. Leave empty to ring all extensions."
msgstr "接收PSTN来电的分机号码。留空则所有分机同时振铃。"

# Trunk descriptions
msgid "Enable/disable this PSTN trunk."
msgstr "启用/禁用此PSTN中继。"

msgid "Unique name to identify this trunk."
msgstr "用于标识此中继的唯一名称。"

msgid "SIP server domain provided by your VoIP provider."
msgstr "VoIP提供商提供的SIP服务器域名。"

msgid "Forward server IP address from China Telecom IMS."
msgstr "中国电信IMS提供的转发服务器IP地址。"

msgid "SIP signaling port (default: 5060)."
msgstr "SIP信令端口（默认：5060）。"

msgid "Your PSTN phone number with country code (e.g., +8612345678901)."
msgstr "带国家代码的PSTN电话号码（例如 +8612345678901）。"

msgid "SIP authentication password from your provider."
msgstr "提供商提供的SIP认证密码。"

msgid "Enable NAT traversal. Keep enabled if Asterisk is behind a router."
msgstr "启用NAT穿透。如果Asterisk在路由器后面，请保持启用。"

msgid "Enable SRTP encryption for secure calls. Only enable if your provider supports it."
msgstr "启用SRTP加密以保护通话安全。仅在提供商支持时启用。"

msgid "Music File Name"
msgstr "音乐文件名"

msgid "Number of times to play the music before dialing (1-6 recommended)"
msgstr "拨号前播放音乐的次数（建议1-6次）"

msgid "PSTN Incoming Handler"
msgstr "PSTN 呼入处理"

msgid "Configure how to handle incoming PSTN calls"
msgstr "配置如何处理 PSTN 呼入电话"

msgid "Choose how to process incoming PSTN calls. Place your .gsm files in /etc/asterisk/sounds/ for IVR prompts, or in /tmp/playback/ for ringback music."
msgstr "选择 PSTN 呼入处理方式。IVR 提示音请将 .gsm 文件放在 /etc/asterisk/sounds/，回铃音乐请放在 /tmp/playback/。"

msgid "PSTN Handler Settings"
msgstr "PSTN 处理设置"

msgid "Incoming Call Mode"
msgstr "呼入模式"

msgid "Normal (Standard Ringback)"
msgstr "普通模式（标准振铃音）"

msgid "Direct Dial with Ringback Music"
msgstr "直拨模式（带回铃音乐）"

msgid "IVR Menu"
msgstr "IVR 菜单"

msgid "Normal: standard ringback tone. Direct Dial: play music then ring extension. IVR Menu: play menu and wait for key press."
msgstr "普通模式：标准振铃音。直拨模式：播放音乐后振铃分机。IVR 菜单：播放菜单等待按键选择。"

msgid "Direct Dial Options"
msgstr "直拨模式选项"

msgid "Enable Ringback Music"
msgstr "启用回铃音乐"

msgid "Music Directory"
msgstr "音乐目录"

msgid "GSM file name without extension (e.g., 'ring' for ring.gsm)"
msgstr "GSM 文件名（不含扩展名，如 ring.gsm 填写 ring）"

msgid "Play Loop Count"
msgstr "播放循环次数"

msgid "IVR Menu Options"
msgstr "IVR 菜单选项"

msgid "Welcome Prompt"
msgstr "欢迎提示音"

msgid "GSM file name without extension (place in /etc/asterisk/sounds/)"
msgstr "GSM 文件名（不含扩展名，放在 /etc/asterisk/sounds/ 目录）"

msgid "GSM file name without extension (placed in the music directory)"
msgid "不带扩展名的GSM文件名（放置在音乐目录中）"

msgid "Timeout (seconds)"
msgstr "超时时间（秒）"

msgid "Invalid Prompt"
msgstr "无效按键提示音"

msgid "IVR Key Mapping"
msgstr "IVR 按键映射"

msgid "Key (0-9)"
msgstr "按键（0-9）"

msgid "Action"
msgstr "动作"

msgid "Dial Extension"
msgstr "拨打分机"

msgid "Hangup"
msgstr "挂断"

msgid "Target"
msgstr "目标"

msgid "Extension number"
msgstr "分机号码"

msgid "PSTN Incoming"
msgstr "PSTN 呼入"

msgid "PSTN Incoming Handler"
msgstr "PSTN 呼入处理"

msgid "Choose how to process incoming PSTN calls. Place your .gsm files in the directory specified below. For ringback music use 'ring.gsm', for IVR use 'ivr-welcome.gsm' and 'ivr-invalid.gsm'."
msgstr "选择 PSTN 来电的处理方式。请将 .gsm 文件放到下面指定的目录中。回铃音乐使用 'ring.gsm'，IVR 使用 'ivr-welcome.gsm' 和 'ivr-invalid.gsm'。"

msgid "PSTN Handler Settings"
msgstr "PSTN 处理设置"


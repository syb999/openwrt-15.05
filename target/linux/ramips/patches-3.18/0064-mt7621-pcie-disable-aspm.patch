--- a/arch/mips/pci/pci-mt7621.c
+++ b/arch/mips/pci/pci-mt7621.c
@@ -797,6 +797,21 @@ pcie(2/1/0) link status	pcie2_num	pcie1_
 		write_config(0, 0, 0, 0x70c, val);
 	}
 
+	/* Disable ASPM L0s/L1 on all active root ports to prevent PCIe link drops */
+	{
+		u32 lnkctl;
+		int port;
+		for (port = 0; port < 3; port++) {
+			if (!(pcie_link_status & (1 << port)))
+				continue;
+			read_config(0, port, 0, 0xF0, &lnkctl);
+			if (lnkctl & 0x03) {
+				printk("PCIe%d: disabling ASPM (linkctl=0x%x)\n", port, lnkctl);
+				write_config(0, port, 0, 0xF0, lnkctl & ~0x03);
+			}
+		}
+	}
+
 	pci_load_of_ranges(&mt7621_controller, pdev->dev.of_node);
 	setup_cm_memory_region(mt7621_controller.mem_resource);
 	register_pci_controller(&mt7621_controller);
